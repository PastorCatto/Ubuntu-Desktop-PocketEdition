#!/bin/sh
# Mobuntu RC16 — initramfs hook: include Qualcomm firmware blobs
# Runs during update-initramfs to bundle firmware into the initrd so that
# remoteproc can load ADSP/CDSP/SLPI firmware at early boot.
PREREQ=""
prereqs() { echo "$PREREQ"; }
case "$1" in prereqs) prereqs; exit 0 ;; esac

. /usr/share/initramfs-tools/hook-functions

FW_DIRS="
    /lib/firmware/qcom
    /lib/firmware/qcom/sdm845
    /lib/firmware/qcom/sdm845/beryllium
    /lib/firmware/qcom/sdm845/Xiaomi/beryllium
"

for dir in $FW_DIRS; do
    [ -d "$dir" ] || continue
    for fw in "$dir"/*.mbn "$dir"/*.bin "$dir"/*.fw "$dir"/*.jsn; do
        [ -f "$fw" ] || continue
        # DESTDIR is set by initramfs-tools to the staging directory root.
        # We must NOT modify DESTDIR itself — derive the dest path from it.
        dest_dir="${DESTDIR}/$(dirname $fw)"
        mkdir -p "$dest_dir"
        cp "$fw" "$dest_dir/"
    done
done

exit 0
